# Port du serveur
PORT=8000

# Token secret pour valider les webhooks GitHub (optionnel mais recommandé)
GITHUB_WEBHOOK_SECRET=change_me

# Nom du bot PR-Agent sur GitHub (pour filtrer ses commentaires)
PR_AGENT_BOT_USERNAME=pr-agent[bot]

# URL de ton instance (pour les liens dans le dashboard)
APP_URL=http://localhost:8000
